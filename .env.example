# ============================================================
# Dind'Or Backend — Variables d'environnement requises
# Copier ce fichier en .env et renseigner les valeurs réelles.
# NE JAMAIS committer .env dans git.
# ============================================================

# --- Base de données ---
DINDOR_DB_USERNAME=root
DINDOR_DB_PASSWORD=your_database_password

# --- Compte Administrateur (initialisation au démarrage) ---
DINDOR_ADMIN_EMAIL=dindorvolaille@gmail.com
DINDOR_ADMIN_PASSWORD=YourSecureAdminPassword@2024
DINDOR_ADMIN_FIRSTNAME=Marouane
DINDOR_ADMIN_LASTNAME=Slama

# --- JWT ---
# Générer avec : openssl rand -base64 48
DINDOR_JWT_SECRET=replace_with_a_random_base64_string_of_at_least_48_characters

# --- Email (Gmail App Password) ---
# Créer un mot de passe d'application sur : https://myaccount.google.com/apppasswords
DINDOR_MAIL_USERNAME=dindorvolaille@gmail.com
DINDOR_MAIL_PASSWORD=xxxx xxxx xxxx xxxx
